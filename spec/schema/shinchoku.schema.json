{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/uiuifree/shinchoku/blob/main/spec/schema/shinchoku.schema.json",
  "title": "shinchoku protocol event (one NDJSON line)",
  "description": "Validates what producers SHOULD write. Consumers are more tolerant than this schema (see SPEC.md §6).",
  "type": "object",
  "required": ["v", "event"],
  "properties": {
    "v": { "const": 1 },
    "event": { "type": "string" }
  },
  "oneOf": [
    {
      "properties": {
        "event": { "const": "start" },
        "title": { "type": "string" },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    {
      "properties": {
        "event": { "const": "progress" },
        "current": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "msg": { "type": "string" }
      },
      "required": ["current"]
    },
    {
      "properties": {
        "event": { "const": "log" },
        "level": { "enum": ["info", "warn", "error"] },
        "msg": { "type": "string" }
      },
      "required": ["level", "msg"]
    },
    {
      "properties": {
        "event": { "const": "metric" },
        "key": { "type": "string" },
        "value": { "type": ["number", "string"] }
      },
      "required": ["key", "value"]
    },
    {
      "properties": {
        "event": { "const": "artifact" },
        "path": { "type": "string" },
        "label": { "type": "string" }
      },
      "required": ["path"]
    },
    {
      "properties": {
        "event": { "const": "done" },
        "summary": { "type": "string" }
      }
    },
    {
      "properties": {
        "event": { "const": "failed" },
        "msg": { "type": "string" }
      },
      "required": ["msg"]
    }
  ]
}
